# Realtime ASR Service Configuration
# Copy to .env and customize

# Service Settings
HOST=0.0.0.0
PORT=8080

# Audio Settings
SAMPLE_RATE=16000
LOCAL_STT_ENABLE_PCM16_FAST_PATH=true
LOCAL_STT_REQUIRE_TARGET_SAMPLE_RATE=true
LOCAL_STT_TARGET_SAMPLE_RATE=16000
# TCP websocket remains the default. Use uds only for colocated sidecar benchmarks/deployments.
LOCAL_STT_SOCKET_MODE=tcp
LOCAL_STT_UDS_PATH=/run/rtc-asr/stt.sock

# ASR Backend Settings
ASR_BACKEND=faster-whisper
ASR_MODEL_SIZE=small.en
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_VAD_FILTER=true
ASR_PRELOAD_MODEL=false
ASR_FAIL_FAST=false

# Optional qwen-asr backend settings
# Set ASR_BACKEND=qwen-asr to enable these.
ASR_QWEN_MODEL=Qwen/Qwen3-ASR-0.6B
ASR_QWEN_DTYPE=auto
# ASR_QWEN_DEVICE_MAP=cuda:0
ASR_QWEN_MAX_NEW_TOKENS=256
ASR_QWEN_MAX_INFERENCE_BATCH_SIZE=1

# Optional parakeet backend settings
# Set ASR_BACKEND=parakeet for the Transformers Parakeet path.
# Set ASR_BACKEND=parakeet-nemo for NeMo-only models such as nvidia/parakeet-tdt_ctc-110m.
# Local Python parakeet runs also need:
# pip install --upgrade --no-deps huggingface-hub==1.18.0 transformers==5.10.2
ASR_PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3
ASR_PARAKEET_DTYPE=auto

# Optional experimental Voxtral backend settings
# Set ASR_BACKEND=voxtral to enable these. Use ASR_PRELOAD_MODEL=true to fail fast
# when the local Transformers runtime is not Voxtral-compatible.
ASR_VOXTRAL_MODEL=mistralai/Voxtral-Mini-4B-Realtime-2602
ASR_VOXTRAL_DTYPE=auto
ASR_VOXTRAL_MAX_NEW_TOKENS=128
ASR_VOXTRAL_TRUST_REMOTE_CODE=true


# GPU Settings (optional)
CUDA_VISIBLE_DEVICES=0

# Legacy aliases still accepted for compatibility:
# MODEL_NAME=small.en
# AUDIO_SAMPLE_RATE=16000
